#!/usr/bin/env bash
set -euo pipefail

start=false
if [[ "${1:-}" == "--start" ]]; then
  start=true
fi

cfg="${XDG_CONFIG_HOME:-$HOME/.config}/eink/settings.json"
hypr_dir="${XDG_CONFIG_HOME:-$HOME/.config}/hypr"
out="${hypr_dir}/hypridle.conf"

have() { command -v "$1" >/dev/null 2>&1; }

screenoff_after=120
sleep_after=900

if [[ -f "$cfg" ]] && have jq; then
  screenoff_after="$(jq -r '.idleScreenOffSeconds // 120' "$cfg" 2>/dev/null || echo 120)"
  sleep_after="$(jq -r '.idleSleepSeconds // 900' "$cfg" 2>/dev/null || echo 900)"
fi

mkdir -p "$hypr_dir"

cat >"$out" <<EOF
# Autogenerated by eink-hypridle-apply

general {
    # Locking: use logind lock-session so sleep can be inhibited until the session is actually locked.
    # See hypridle docs: general:inhibit_sleep = 3 waits for the session-lock notification.
    lock_cmd = pidof hyprlock || hyprlock
    before_sleep_cmd = loginctl lock-session || hyprlock
    after_sleep_cmd = hyprctl dispatch dpms on
    inhibit_sleep = 3
}

listener {
    timeout = ${screenoff_after}
    on-timeout = hyprctl dispatch dpms off
    on-resume = hyprctl dispatch dpms on
}

listener {
    timeout = ${sleep_after}
    on-timeout = systemctl suspend
}
EOF

if $start && have hypridle; then
  # Restart hypridle to pick up changes (best-effort).
  pkill -x hypridle >/dev/null 2>&1 || true
  (hypridle -c "$out" >/dev/null 2>&1 & disown) || true
fi
