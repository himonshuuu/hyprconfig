#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  eink-wallpaper /abs/path/to/wallpaper.(png|jpg|...)
  eink-wallpaper --restore

What it does:
  - sets wallpaper via swww (starts daemon if needed)
  - generates ~/.cache/quickshell/eink/colors.json via matugen
  - generates ~/.config/kitty/colors-eink.conf from matugen base16
EOF
}

restore=false
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi
if [[ "${1:-}" == "--restore" ]]; then
  restore=true
  shift || true
fi

wallpaper_path="${1:-}"
cfg_dir="${XDG_CONFIG_HOME:-$HOME/.config}/eink"
cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/quickshell/eink"
kitty_dir="${XDG_CONFIG_HOME:-$HOME/.config}/kitty"
rofi_dir="${XDG_CONFIG_HOME:-$HOME/.config}/rofi"
swaync_dir="${XDG_CONFIG_HOME:-$HOME/.config}/swaync"
hypr_dir="${XDG_CONFIG_HOME:-$HOME/.config}/hypr"

mkdir -p "$cfg_dir" "$cache_dir" "$kitty_dir" "$rofi_dir" "$swaync_dir" "$hypr_dir"

wallpaper_file="$cfg_dir/wallpaper"

if $restore; then
  if [[ -s "$wallpaper_file" ]]; then
    wallpaper_path="$(head -n 1 "$wallpaper_file")"
  else
    exit 0
  fi
fi

if [[ -z "$wallpaper_path" ]]; then
  echo "eink-wallpaper: missing wallpaper path" >&2
  usage >&2
  exit 2
fi

if [[ "$wallpaper_path" != /* ]]; then
  wallpaper_path="$(realpath "$wallpaper_path")"
fi
if [[ ! -f "$wallpaper_path" ]]; then
  echo "eink-wallpaper: not a file: $wallpaper_path" >&2
  exit 2
fi

echo "$wallpaper_path" > "$wallpaper_file"

if command -v swww >/dev/null 2>&1; then
  if ! swww query >/dev/null 2>&1; then
    (swww-daemon >/dev/null 2>&1 &) || true
    sleep 0.2
  fi

  # Never abort theme generation if wallpaper setting fails.
  swww img "$wallpaper_path" \
    --transition-type grow \
    --transition-duration 0.9 \
    --transition-fps 60 \
    --transition-pos 0.5,0.3 >/dev/null 2>&1 || true
fi

tmp_json="$(mktemp)"
cleanup() { rm -f "$tmp_json"; }
trap cleanup EXIT

{
  # matugen sometimes fails to decode specific images (bad/corrupt JPEGs, mislabeled formats, etc).
  # Never abort the wallpaper apply because of palette generation; we can fall back to a neutral palette.
  matugen image "$wallpaper_path" -m dark -j hex --dry-run --source-color-index 0 --quiet >"$tmp_json" 2>/dev/null || true
  if ! jq -e '.colors? // empty' <"$tmp_json" >/dev/null 2>&1; then
    matugen image "$wallpaper_path" -m dark -j hex --dry-run --source-color-index 0 \
      --fallback-color "#d9c76f" --continue-on-error --quiet >"$tmp_json" 2>/dev/null || true
  fi
} || true

colors_out="$cache_dir/colors.json"

# If the wallpaper is essentially grayscale, use a clean white accent.
# "Grayscale" detection is done in two ways to handle tinted/noisy B/W images:
#  1) mean saturation in HSL (near 0)
if command -v magick >/dev/null 2>&1; then
  # In ImageMagick, HSL channels map as: R=Hue, G=Saturation, B=Lightness.
  sat_mean="$(magick "$wallpaper_path" -resize 96x96\! -colorspace HSL -format "%[fx:mean.g]" info: 2>/dev/null || true)"
  is_gray=0
  if [[ -n "${sat_mean:-}" ]]; then
    is_gray="$(awk -v s="$sat_mean" 'BEGIN{ if (s+0 < 0.12) print 1; else print 0 }' 2>/dev/null || echo 0)"
  fi

  if [[ "$is_gray" == "1" ]]; then
    cat >"$tmp_json" <<'JSON'
{
  "colors": {
    "primary": { "dark": { "color": "#ffffff" } },
    "on_primary": { "dark": { "color": "#000000" } },
    "surface_container_high": { "dark": { "color": "#2b2a28" } },
    "surface_container": { "dark": { "color": "#22211f" } },
    "outline_variant": { "dark": { "color": "#4a4739" } },
    "on_surface": { "dark": { "color": "#efe9db" } },
    "on_surface_variant": { "dark": { "color": "#cdc6b4" } }
  }
}
JSON
  fi
fi

# If matugen fails hard (or outputs nothing/invalid JSON), ensure we still write a palette
# so quickshell theme updates instead of sticking to the previous colors.json.
if ! jq -e '.colors.primary.dark.color? // .colors.primary.color? // empty' <"$tmp_json" >/dev/null 2>&1; then
  cat >"$tmp_json" <<'JSON'
{
  "colors": {
    "primary": { "dark": { "color": "#ffffff" } },
    "on_primary": { "dark": { "color": "#000000" } },
    "surface_container_high": { "dark": { "color": "#2b2a28" } },
    "surface_container": { "dark": { "color": "#22211f" } },
    "outline_variant": { "dark": { "color": "#4a4739" } },
    "on_surface": { "dark": { "color": "#efe9db" } },
    "on_surface_variant": { "dark": { "color": "#cdc6b4" } }
  }
}
JSON
fi

# Write in-place (not atomic replace) so FileView watchers reliably see updates.
cat "$tmp_json" >"$colors_out"
chmod 0644 "$colors_out" 2>/dev/null || true

# Rofi: update selection (accent) colors to match the dynamic theme.
rofi_colors="$rofi_dir/eink-colors.rasi"
accent_hex="$(jq -r '.colors.primary.dark.color // .colors.primary.color // "#929521"' <"$tmp_json" 2>/dev/null || echo "#929521")"
on_accent_hex="$(jq -r '.colors.on_primary.dark.color // .colors.on_primary.color // "#0b0b0b"' <"$tmp_json" 2>/dev/null || echo "#0b0b0b")"
accent_hex="${accent_hex#\#}"
on_accent_hex="${on_accent_hex#\#}"
hex_to_rgb() {
  local h="$1"
  [[ "$h" =~ ^[0-9a-fA-F]{6}$ ]] || return 1
  local r g b
  r=$((16#${h:0:2}))
  g=$((16#${h:2:2}))
  b=$((16#${h:4:2}))
  printf '%s %s %s' "$r" "$g" "$b"
}
if rgb="$(hex_to_rgb "$accent_hex" 2>/dev/null)"; then
  read -r ar ag ab <<<"$rgb"
else
  ar=146; ag=149; ab=33
fi
{
  echo "/* Autogenerated by ~/.local/bin/eink-wallpaper */"
  echo "* {"
  echo "  accent: #${accent_hex};"
  echo "  on-accent: #${on_accent_hex};"
  echo "  border-accent: rgba(${ar}, ${ag}, ${ab}, 0.40);"
  echo "}"
  echo
} >"$rofi_colors"
chmod 0644 "$rofi_colors" 2>/dev/null || true

# SwayNC: update accent colors and reload styles if possible.
swaync_colors="$swaync_dir/eink-colors.css"
{
  echo "/* Autogenerated by ~/.local/bin/eink-wallpaper */"
  echo "@define-color accent #${accent_hex};"
  echo "@define-color on-accent #${on_accent_hex};"
  echo "@define-color border-accent rgba(${ar}, ${ag}, ${ab}, 0.40);"
  echo "@define-color accent-soft rgba(${ar}, ${ag}, ${ab}, 0.55);"
  echo "@define-color accent-strong rgba(${ar}, ${ag}, ${ab}, 0.65);"
} >"$swaync_colors"
chmod 0644 "$swaync_colors" 2>/dev/null || true

if command -v swaync-client >/dev/null 2>&1; then
  swaync-client -rs >/dev/null 2>&1 || true
fi

# Hyprlock: generate lockscreen config using current wallpaper + dynamic colors.
hyprlock_conf="$hypr_dir/hyprlock.conf"
surface_hex="$(jq -r '.colors.surface_container_high.dark.color // .colors.surface_container_high.color // "#2b2a28"' <"$tmp_json" 2>/dev/null || echo "#2b2a28")"
outline_hex="$(jq -r '.colors.outline_variant.dark.color // .colors.outline_variant.color // "#4a4739"' <"$tmp_json" 2>/dev/null || echo "#4a4739")"
text_hex="$(jq -r '.colors.on_surface.dark.color // .colors.on_surface.color // "#efe9db"' <"$tmp_json" 2>/dev/null || echo "#efe9db")"
muted_hex="$(jq -r '.colors.on_surface_variant.dark.color // .colors.on_surface_variant.color // "#cdc6b4"' <"$tmp_json" 2>/dev/null || echo "#cdc6b4")"
surface_hex="${surface_hex#\#}"
outline_hex="${outline_hex#\#}"
text_hex="${text_hex#\#}"
muted_hex="${muted_hex#\#}"

{
  echo "# Autogenerated by ~/.local/bin/eink-wallpaper"
  echo
  echo "general {"
  echo "    disable_loading_bar = true"
  echo "    hide_cursor = true"
  echo "    grace = 0"
  echo "}"
  echo
  echo "background {"
  # hyprlock config does not support quoted strings reliably; escape spaces.
  wp_esc="${wallpaper_path//\\/\\\\}"
  wp_esc="${wp_esc// /\\ }"
  echo "    path = ${wp_esc}"
  echo "    color = rgba(000000ee)"
  echo "    blur_passes = 2"
  echo "    blur_size = 7"
  echo "    noise = 0.0117"
  echo "    contrast = 0.90"
  echo "    brightness = 0.82"
  echo "}"
  echo
  echo "label {"
  echo "    text = \$TIME"
  echo "    color = rgba(${accent_hex}ff)"
  echo "    font_size = 64"
  echo "    font_family = Google Sans"
  echo "    position = 0, 80"
  echo "    halign = center"
  echo "    valign = center"
  echo "    shadow_passes = 2"
  echo "    shadow_size = 4"
  echo "    shadow_color = rgba(000000aa)"
  echo "}"
  echo
  echo "input-field {"
  echo "    size = 260, 48"
  echo "    outline_thickness = 2"
  echo "    dots_center = true"
  echo "    dots_spacing = 0.35"
  echo "    dots_rounding = -1"
  echo "    fade_on_empty = true"
  echo "    placeholder_text = <span foreground=\"##${muted_hex}\">Password</span>"
  echo "    outer_color = rgba(${outline_hex}66)"
  echo "    inner_color = rgba(${surface_hex}cc)"
  echo "    font_color = rgba(${text_hex}ff)"
  echo "    check_color = rgba(${accent_hex}00)"
  echo "    fail_color = rgba(ff5c5cff)"
  echo "    position = 0, -40"
  echo "    halign = center"
  echo "    valign = center"
  echo "}"
  echo
} >"$hyprlock_conf"
chmod 0644 "$hyprlock_conf" 2>/dev/null || true

# Hyprland: match active border to the current accent.
if command -v hyprctl >/dev/null 2>&1; then
  accent_hex="$(jq -r '.colors.primary.dark.color // .colors.primary.color // "#ffffff"' <"$tmp_json" 2>/dev/null || echo "#ffffff")"
  accent_hex="${accent_hex#\#}"
  if [[ "$accent_hex" =~ ^[0-9a-fA-F]{6}$ ]]; then
    hyprctl keyword general:col.active_border "rgba(${accent_hex}ff) rgba(${accent_hex}99) 45deg" >/dev/null 2>&1 || true
  fi
fi

# Kitty base16 theme from matugen output.
kitty_colors="$kitty_dir/colors-eink.conf"
{
  echo "# Autogenerated by ~/.local/bin/eink-wallpaper"
  echo
  base() { jq -r ".base16.${1}.dark.color // empty" <"$tmp_json"; }

  echo "background $(base base00)"
  echo "foreground $(base base05)"
  echo
  echo "color0  $(base base00)"
  echo "color1  $(base base08)"
  echo "color2  $(base base0B)"
  echo "color3  $(base base0A)"
  echo "color4  $(base base0D)"
  echo "color5  $(base base0E)"
  echo "color6  $(base base0C)"
  echo "color7  $(base base05)"
  echo "color8  $(base base03)"
  echo "color9  $(base base08)"
  echo "color10 $(base base0B)"
  echo "color11 $(base base0A)"
  echo "color12 $(base base0D)"
  echo "color13 $(base base0E)"
  echo "color14 $(base base0C)"
  echo "color15 $(base base07)"
} >"$kitty_colors"

echo "eink-wallpaper: updated theme from $wallpaper_path"
